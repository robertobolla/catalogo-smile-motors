/*
  Cache-Control: public, max-age=300, stale-while-revalidate=604800

/assets/img/*.webp
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept

/assets/img/*.png
  Cache-Control: public, max-age=31536000, immutable

/assets/img/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/css/*.css
  Cache-Control: public, max-age=31536000, immutable

/js/*.js
  Cache-Control: public, max-age=31536000, immutable

/assets/favicon.png
  Cache-Control: public, max-age=86400
